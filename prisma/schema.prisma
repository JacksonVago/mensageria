  emvPIX          String? //Código EMV para pagamento via PIX
  metodoPagamento String? //Método de pagamento utilizado
  status          String? //Status do boleto
  observacao      String?
  txid            String? //txID do PIX quando for híbrido
  qrcode          String? //QR CODE do PIX quando for híbrido

  pagtoParcial   Boolean? @default(false) //Indica se o alerta está ativo ou não
  qtdeMaxParcial Int? //Quantide de pagamentos parcial 1..99
  formaEnvio     String?
  email          String?
  assuntoEmail   String?
  mensagemEmail1 String?
  mensagemEmail2 String?
  mensagemEmail3 String?

  tipoJurosCobCod String?
  valorJuros      Float?
  percJuros       Float?
  diasInicioJuros Int?

  tipoMultaCobCod String?
  valorMulta      Float?
  percMulta       Float?
  diasInicioMulta Int?

  tipoDescontoCobCod String?
  valorDesconto      Float?
  percDesconto       Float?
  diasInicioDesconto Int?

  tipoAutorizacaoCobCod String?
  tipoRecebimentoDiv    String?
  valorMinDiverg        Float?
  valorMaxDiverg        Float?
  percMinDiverg         Float?
  percMaxDiverg         Float?

  protestar         Boolean?
  qtdeDiasProtesto  Int?
  negativar         Boolean?
  qtdeDiasNegativar Int?

  instrucaoCobCod1 String?
  instrucaoCobCod2 String?
  instrucaoCobCod3 String?

  instrucaoRecCod1 String?
  instrucaoRecCod2 String?
  instrucaoRecCod3 String?
  instrucaoRecCod4 String?

  carteiraCod String?

  especieCod String?
  createdAt  DateTime @default(now())

  updatedAt DateTime @updatedAt

  contacorrente ContaCorrente? @relation(fields: [contaId], references: [id])
  contaId       Int?

  @@map("boletosbancarios")
}

model LancamentoCondominio {
  id                   Int              @id @default(autoincrement())
