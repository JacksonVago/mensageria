  locacao   Locacao @relation(fields: [locacaoId], references: [id])
  locacaoId Int
  boleto    Boleto? @relation(fields: [boletoId], references: [id])
  boletoId  Int?

  @@map("lancamentoslocacoes")
}

model LancamentoImovel {
  id                   Int              @id @default(autoincrement())
  lancamentotipo       LancamentoTipo   @relation(fields: [tipoId], references: [id])
  parcela              Int? //Parcela do lançamento no caso de lançamento com número de parcelas
  tipoId               Int //Tipo de lançamnto (IPTU, CONDOMINIO, ÁGUA, LUZ, etc..)
  valorLancamento      Float //Valor do lançamento
  dataLancamento       DateTime
  vencimentoLancamento DateTime
  linhaDigitavel       String? //Linha digitável do boleto gerado para esse lançamento
  observacao           String
  status               lancamentoStatus @default(ABERTO)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  imovel   Imovel  @relation(fields: [imovelId], references: [id])
  imovelId Int
  boleto   Boleto? @relation(fields: [boletoId], references: [id])
  boletoId Int?

  @@map("lancamentosimoveis")
}

model Boleto {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locacao   Locacao? @relation(fields: [locacaoId], references: [id])
  locacaoId Int?

  imovel   Imovel? @relation(fields: [imovelId], references: [id])
  imovelId Int?

  status         BoletoStatus @default(PENDENTE) //Status do boleto (pendente, pago, atrasado...)  
  dataEmissao    DateTime //date de emissão do boleto
  dataVencimento DateTime //Data de vencimento do boleto
  dataPagamento  DateTime? //Data de pagamento do boleto

  valorOriginal Float //Valor do boleto
  valorPago     Float? //Valor do boleto

  locatario      Locatario? @relation(fields: [locatarioId], references: [id])
  locatarioId    Int?
  linhaDigitavel String?
  observacao     String?

